# Normaliza finais de linha: LF no repositório, nativo no working copy.
* text=auto

# Garante LF nestes, independente do sistema.
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf

# Binários: git nunca deve tentar converter.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
